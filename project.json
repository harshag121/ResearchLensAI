  "deployment_guide": {
    "local": {
      "steps": [
        "1. Clone Endee repo and star it: git clone https://github.com/endee-io/endee.git",
        "2. Start Endee: docker run -d -p 8080:8080 endeeio/endee-server:latest",
        "3. Clone ResearchLens: git clone <your-repo>",
        "4. Install: pip install -r requirements.txt",
        "5. Configure: cp .env.example .env && edit",
        "6. Initialize: python scripts/init_index.py",
        "7. Load data: python scripts/load_sample_data.py",
        "8. Run backend: uvicorn app.main:app --reload",
        "9. Run frontend: streamlit run frontend/streamlit_app.py"
      ]
    },
    "docker": {
      "steps": [
        "1. docker-compose up -d",
        "2. Wait for health check (Endee ready)",
        "3. Run init script: docker exec researchlens-backend python scripts/init_index.py",
        "4. Load data: docker exec researchlens-backend python scripts/load_sample_data.py",
        "5. Access: Backend http://localhost:8000, Frontend http://localhost:8501"
      ]
    }
  },

