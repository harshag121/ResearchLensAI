  "endee_integration_patterns": {
    "index_creation": {
      "code": "from endee import Endee, Precision\n\nclient = Endee(token=ENDEE_TOKEN)\nclient.set_base_url(ENDEE_HOST + '/api/v1')\n\nclient.create_index(\n    name='academic_papers',\n    dimension=384,\n    space_type='cosine',\n    sparse_model='default',\n    precision=Precision.INT8,\n    M=32,\n    ef_con=200\n)",
      "notes": "sparse_model='default' enables hybrid search with BM25-style sparse vectors"
    },

    "vector_upsert": {
      "code": "index = client.get_index('academic_papers')\n\nvectors = [\n    {\n        'id': 'paper_001',\n        'vector': [0.1, 0.2, ...],  # 384-dim dense embedding\n        'sparse_indices': [1, 5, 23, ...],  # BM25 term positions\n        'sparse_values': [0.5, 0.3, 0.8, ...],  # BM25 weights\n        'meta': {\n            'title': 'Paper Title',\n            'abstract': 'Paper abstract...',\n            'authors': ['Author1', 'Author2'],\n            'year': 2024,\n            'field': 'cs.AI'\n        },\n        'filter': {\n            'year': 2024,\n            'field': 'cs.AI',\n            'citation_count': 150\n        }\n    }\n]\n\nindex.upsert(vectors)",
      "notes": "Max 1000 vectors per batch. sparse_indices and sparse_values required for hybrid search."
    },

    "semantic_search": {
      "code": "results = index.query(\n    vector=query_embedding,\n    top_k=10,\n    ef=128,\n    include_vectors=False,\n    filter=[\n        {'year': {'$range': [2020, 2024]}},\n        {'field': {'$in': ['cs.AI', 'cs.LG']}},\n        {'citation_count': {'$gte': 50}}\n    ]\n)",
      "notes": "Filter operators: $eq, $in, $range. Range values must be 0-999."
    },

    "hybrid_search": {
      "code": "results = index.query(\n    vector=dense_query,\n    sparse_indices=sparse_indices,\n    sparse_values=sparse_values,\n    top_k=10,\n    ef=128,\n    include_vectors=False\n)",
      "notes": "Combines dense semantic + sparse keyword matching for better relevance"
    },

    "filtered_query_tuning": {
      "code": "results = index.query(\n    vector=query_embedding,\n    top_k=10,\n    filter=[{'field': {'$eq': 'cs.AI'}}],\n    prefilter_cardinality_threshold=5000,\n    filter_boost_percentage=30\n)",
      "notes": "prefilter_cardinality_threshold: 1000-1000000 (default 10000). filter_boost_percentage: 0-100 (default 0)"
    },

    "get_index_stats": {
      "code": "stats = index.describe()\nprint(f\"Vector count: {stats['vector_count']}\")\nprint(f\"Index size: {stats['index_size_mb']} MB\")",
      "notes": "Returns vector count, memory usage, and index configuration"
    },

    "delete_vector": {
      "code": "index.delete_vector('paper_001')",
      "notes": "Delete single vector by ID"
    },

    "delete_with_filter": {
      "code": "index.delete_with_filter([{'year': {'$eq': 2020}}])",
      "notes": "Delete multiple vectors matching filter conditions"
    }
  },

  "filter_operators": {
    "$eq": {
      "description": "Equal to",
      "types": ["string", "number"],
      "example": "{'year': {'$eq': 2024}}"
    },
    "$in": {
      "description": "In list",
      "types": ["string"],
      "example": "{'field': {'$in': ['cs.AI', 'cs.LG']}}"
    },
    "$range": {
      "description": "Between range (inclusive)",
      "types": ["number"],
      "example": "{'citation_count': {'$range': [50, 500]}}",
      "constraint": "Values must be 0-999. Normalize larger values."
    }
  },

  "precision_levels": {
    "FLOAT32": {"memory": "100%", "accuracy": "Maximum", "use_case": "Critical accuracy"},
    "FLOAT16": {"memory": "50%", "accuracy": "Very good", "use_case": "Good accuracy balance"},
    "INT16": {"memory": "50%", "accuracy": "Very good", "use_case": "Default recommendation"},
    "INT8": {"memory": "25%", "accuracy": "Good", "use_case": "Production (recommended)"},
    "BINARY2": {"memory": "3.1%", "accuracy": "Lower", "use_case": "Extreme scale"}
  },

