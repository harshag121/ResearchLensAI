{
  "project": {
    "name": "ResearchLens AI",
    "version": "1.0.0",
    "description": "Intelligent Academic Research Assistant powered by Endee Vector Database",
    "internship_evaluation": {
      "company": "Endee",
      "requirements": [
        "Star Endee GitHub repository",
        "Well-defined AI/ML project",
        "Practical use case with semantic search",
        "Endee as core vector database",
        "GitHub repository with comprehensive README",
        "Working demo with documentation"
      ]
    }
  },
  
  "tech_stack": {
    "vector_database": {
      "name": "Endee",
      "version": "0.1.20+",
      "pypi": "endee",
      "github": "https://github.com/endee-io/endee",
      "features_used": [
        "Hybrid search (dense + sparse vectors)",
        "Metadata filtering with $eq, $in, $range operators",
        "INT8 quantization for memory efficiency",
        "HNSW indexing for fast ANN search",
        "Batch upsert (max 1000 vectors)",
        "Filtered querying with prefilter_cardinality_threshold"
      ]
    },
    "embeddings": {
      "model": "sentence-transformers/all-MiniLM-L6-v2",
      "dimension": 384,
      "library": "sentence-transformers"
    },
    "backend": {
      "framework": "FastAPI",
      "version": "0.109.0+",
      "async": true
    },
    "frontend": {
      "framework": "Streamlit",
      "version": "1.31.0+"
    },
    "llm": {
      "provider": "OpenAI",
      "model": "gpt-4-turbo",
      "alternative": "anthropic/claude-3-sonnet"
    },
    "python_version": "3.9+"
  },

