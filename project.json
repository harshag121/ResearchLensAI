          "path": "/api/v1/papers",
          "method": "POST",
          "function": "upload_papers",
          "description": "Upload single or multiple papers"
        },
        {
          "path": "/api/v1/papers/batch",
          "method": "POST",
          "function": "batch_upload",
          "description": "Batch upload up to 1000 papers"
        }
      ],
      "endee_usage": {
        "upsert": "index.upsert([vector_objects])",
        "batch_size": 1000,
        "vector_object": {
          "id": "paper_id",
          "vector": "[384-dim embedding]",
          "sparse_indices": "[BM25 term indices]",
          "sparse_values": "[BM25 term weights]",
          "meta": ["title", "abstract", "authors", "year", "field"],
          "filter": ["year", "field", "citation_count"]
        }
      }
    },

    "app/routers/chat.py": {
      "description": "RAG-based chat endpoint",
