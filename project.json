  "file_implementations": {
    "requirements.txt": {
      "content": "endee>=0.1.20\nfastapi>=0.109.0\nuvicorn[standard]>=0.27.0\nstreamlit>=1.31.0\nsentence-transformers>=2.3.0\nopenai>=1.12.0\npython-dotenv>=1.0.0\npydantic>=2.6.0\nhttpx>=0.26.0\nnumpy>=1.24.0\npandas>=2.0.0\npytest>=8.0.0\npytest-asyncio>=0.23.0\naiofiles>=23.2.0\npython-multipart>=0.0.6"
    },

    ".env.example": {
      "content": "# Endee Configuration\nENDEE_HOST=http://localhost:8080\nENDEE_TOKEN=your-endee-token-here\nENDEE_INDEX_NAME=academic_papers\n\n# Embedding Model\nEMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2\nEMBEDDING_DIMENSION=384\n\n# OpenAI Configuration\nOPENAI_API_KEY=sk-your-openai-key-here\nOPENAI_MODEL=gpt-4-turbo\n\n# Application Settings\nAPP_HOST=0.0.0.0\nAPP_PORT=8000\nDEBUG=true\n\n# Streamlit\nSTREAMLIT_PORT=8501"
    },

    "docker-compose.yml": {
      "content": "version: '3.8'\n\nservices:\n  endee:\n    image: endeeio/endee-server:latest\n    container_name: endee-server\n    ports:\n      - \"8080:8080\"\n    volumes:\n      - endee-data:/data\n    environment:\n      - ENDEE_PORT=8080\n      - ENDEE_DATA_PATH=/data\n    restart: unless-stopped\n    healthcheck:\n      test: [\"CMD\", \"curl\", \"-f\", \"http://localhost:8080/health\"]\n      interval: 30s\n      timeout: 10s\n      retries: 3\n\n  backend:\n    build: .\n    container_name: researchlens-backend\n    ports:\n      - \"8000:8000\"\n    environment:\n      - ENDEE_HOST=http://endee:8080\n      - ENDEE_TOKEN=${ENDEE_TOKEN}\n      - OPENAI_API_KEY=${OPENAI_API_KEY}\n    depends_on:\n      endee:\n        condition: service_healthy\n    volumes:\n      - ./app:/app/app\n      - ./core:/app/core\n      - ./data:/app/data\n    command: uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload\n\n  frontend:\n    image: python:3.11-slim\n    container_name: researchlens-frontend\n    ports:\n      - \"8501:8501\"\n    working_dir: /app\n    volumes:\n      - ./frontend:/app/frontend\n      - ./data:/app/data\n    command: |\n      pip install streamlit requests && \n      streamlit run frontend/streamlit_app.py --server.port 8501 --server.address 0.0.0.0\n    depends_on:\n      - backend\n\nvolumes:\n  endee-data:"
    },

    "core/endee_client.py": {
      "description": "Endee vector database client manager with connection pooling",
      "implementation_notes": [
        "Initialize Endee client with token from environment",
        "Create hybrid index with sparse_model='default' for BM25",
        "Use Precision.INT8 for memory efficiency",
        "Implement connection health check",
        "Handle index creation if not exists"
      ],
      "key_functions": [
        "get_client() - Returns singleton Endee client",
        "create_index() - Creates academic_papers index with hybrid search",
        "get_index() - Gets index reference",
        "check_health() - Verifies Endee connection"
      ],
      "endee_config": {
        "index_name": "academic_papers",
        "dimension": 384,
        "space_type": "cosine",
        "precision": "Precision.INT8",
        "sparse_model": "default",
        "M": 32,
        "ef_con": 200
      }
    },

    "core/embeddings.py": {
      "description": "Text embedding service using sentence-transformers",
      "implementation_notes": [
        "Load all-MiniLM-L6-v2 model (384 dimensions)",
        "Implement batch encoding for efficiency",
        "Cache embeddings for repeated queries",
        "Normalize vectors for cosine similarity"
      ],
      "key_functions": [
        "get_embedding_model() - Returns singleton model",
        "encode_text(text) - Encode single text to vector",
        "encode_batch(texts) - Encode multiple texts efficiently",
        "normalize_vector(vector) - L2 normalize for cosine search"
      ]
    },

    "core/rag_engine.py": {
      "description": "RAG pipeline for generating answers with cited sources",
      "implementation_notes": [
        "Retrieve top-k relevant papers from Endee",
        "Construct context from paper abstracts",
        "Prompt LLM with context and question",
        "Include citations in response"
      ],
      "key_functions": [
        "retrieve_context(query, top_k=5) - Get relevant papers from Endee",
        "generate_answer(question, context) - LLM generation",
        "rag_query(query, top_k=5) - Full RAG pipeline"
      ],
      "prompt_template": "You are a research assistant. Answer the question using the provided context from academic papers. Include citations with paper IDs.\n\nContext:\n{context}\n\nQuestion: {question}\n\nAnswer:"
    },

    "core/paper_processor.py": {
      "description": "Process academic papers for ingestion",
      "implementation_notes": [
        "Extract text from PDF or JSON",
        "Generate dense embeddings",
        "Generate sparse vectors (BM25-style)",
        "Extract metadata (year, authors, field, citations)"
      ],
      "key_functions": [
        "process_paper(paper_dict) - Process single paper",
        "extract_metadata(paper) - Extract structured metadata",
        "generate_sparse_vector(text) - Create BM25-style sparse representation"
      ]
    },

    "app/config.py": {
      "description": "Application configuration from environment variables",
      "content_structure": {
        "classes": ["Settings (Pydantic BaseModel)"],
        "settings": [
          "endee_host",
          "endee_token",
          "endee_index_name",
          "embedding_model",
          "embedding_dimension",
          "openai_api_key",
          "openai_model",
          "app_host",
          "app_port"
        ]
      }
    },

    "app/models.py": {
      "description": "Pydantic models for API request/response",
      "models": [
        {
          "name": "SearchRequest",
          "fields": ["query: str", "top_k: int = 10", "filters: Optional[dict]", "hybrid: bool = True"]
        },
        {
          "name": "SearchResponse",
          "fields": ["results: List[PaperResult]", "query_time_ms: float"]
        },
        {
          "name": "PaperResult",
          "fields": ["id: str", "title: str", "similarity: float", "metadata: dict"]
        },
        {
          "name": "ChatRequest",
          "fields": ["question: str", "top_k: int = 5"]
        },
        {
          "name": "ChatResponse",
          "fields": ["answer: str", "sources: List[PaperResult]", "query_time_ms: float"]
        },
        {
          "name": "UploadRequest",
          "fields": ["papers: List[dict]"]
        }
      ]
    },

    "app/main.py": {
      "description": "FastAPI application entry point",
      "implementation_notes": [
        "Initialize FastAPI app with CORS",
        "Include routers (search, upload, chat)",
        "Add startup event for Endee connection",
        "Add health check endpoint"
      ],
      "endpoints": [
        {"path": "/", "method": "GET", "description": "Root endpoint"},
        {"path": "/health", "method": "GET", "description": "Health check"},
        {"path": "/api/v1/search", "method": "POST", "description": "Semantic search"},
        {"path": "/api/v1/search/hybrid", "method": "POST", "description": "Hybrid search"},
        {"path": "/api/v1/papers", "method": "POST", "description": "Upload papers"},
        {"path": "/api/v1/papers/batch", "method": "POST", "description": "Batch upload"},
        {"path": "/api/v1/chat", "method": "POST", "description": "RAG chat"},
        {"path": "/api/v1/recommend/{paper_id}", "method": "GET", "description": "Similar papers"},
        {"path": "/api/v1/stats", "method": "GET", "description": "Index statistics"}
      ]
    },

    "app/routers/search.py": {
      "description": "Search endpoints for paper discovery",
      "endpoints": [
        {
          "path": "/api/v1/search",
          "method": "POST",
          "function": "semantic_search",
          "description": "Dense vector similarity search with filters"
        },
        {
          "path": "/api/v1/search/hybrid",
          "method": "POST",
          "function": "hybrid_search",
          "description": "Combined dense + sparse vector search"
        }
      ],
      "endee_usage": {
        "semantic_search": "index.query(vector=embedding, top_k=top_k, filter=filters)",
        "hybrid_search": "index.query(vector=dense, sparse_indices=sparse_idx, sparse_values=sparse_val, top_k=top_k)"
      }
    },

    "app/routers/upload.py": {
      "description": "Paper ingestion endpoints",
      "endpoints": [
